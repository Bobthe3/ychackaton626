{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video",
  "description": "One video payload served by Devan's Cloudflare API. NOTE: color_profile is intentionally absent — Holly extracts it client-side keyed by video_id.",
  "type": "object",
  "required": ["video_id", "url", "characteristics", "metadata"],
  "properties": {
    "video_id": { "type": "string", "format": "uuid" },
    "url": { "type": "string", "format": "uri", "description": "MP4 url on Cloudflare R2" },
    "characteristics": {
      "type": "object",
      "required": ["audio", "transcript_summary", "cut_count", "on_screen_text"],
      "properties": {
        "audio": { "type": "string", "description": "short: music | VO | music+VO" },
        "transcript_summary": { "type": "string", "description": "1-3 lines; include a short title" },
        "cut_count": { "type": "integer", "minimum": 0 },
        "on_screen_text": { "type": "string" },
        "subtitles": { "type": "boolean" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["duration_ms", "creator"],
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 },
        "created_at": { "type": "string", "format": "date" },
        "creator": { "type": "string" },
        "likes": { "type": "integer" },
        "shares": { "type": "integer" }
      }
    }
  }
}
