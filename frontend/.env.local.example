# Copy to .env.local (gitignored) and fill in. NEVER commit real keys.

# OpenAI (sponsor) — for the chat/decode API in Screen 2
OPENAI_API_KEY=sk-...

# Orange Slice (sponsor) — powers the live "GTM · Orange Slice" tab (/api/gtm).
# Two ways to authenticate on a given machine:
#   1) run `npx orangeslice login` (saves a key to ~/.config/orangeslice/config.json), OR
#   2) set this env var to a shared key (uses that org's credits).
# Without either, the GTM tab still works via a bundled fallback (not a live call).
ORANGESLICE_API_KEY=osk_...

# Devan's Cloudflare API base (video + characteristics). Use mocks until ready.
NEXT_PUBLIC_VIDEO_API_BASE=http://localhost:8788

# Devan's local EEG WebSocket server. Confirm port + sample rate with him.
NEXT_PUBLIC_EEG_WS_URL=ws://localhost:8765
