# Base URL of the local API server (see ./server). For local dev:
#   EXPO_PUBLIC_API_BASE=http://localhost:8787
# On a physical device use your machine's LAN IP, e.g. http://192.168.1.20:8787
#
# Leave UNSET to run in mock mode: local access codes + bundled sample videos,
# events logged to the console instead of POSTed.
EXPO_PUBLIC_API_BASE=
