{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_API_BASE": "" }
    },
    "preview": {
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_API_BASE": "" }
    },
    "testflight": {
      "ios": {
        "distribution": "store",
        "autoIncrement": "buildNumber"
      },
      "env": { "EXPO_PUBLIC_API_BASE": "" }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "ascApiKeyPath": "$EXPO_ASC_API_KEY_PATH",
        "ascApiKeyId": "$EXPO_ASC_KEY_ID",
        "ascApiKeyIssuerId": "$EXPO_ASC_ISSUER_ID",
        "ascAppId": "6782643444",
        "appName": "FlowState Testing",
        "language": "en-US",
        "sku": "flowstate-testing"
      }
    }
  }
}
